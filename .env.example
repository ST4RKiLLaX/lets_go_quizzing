# Optional. For basic use, complete setup in the web UI. These override config file values.

# Legacy/migration: password for hosting when no config exists.
# HOST_PASSWORD=changeme

# Production only: comma-separated origins for Socket.io CORS.
# Example: ORIGIN=https://quiz.example.com,https://www.quiz.example.com
# For local dev (Vite on 5173): ORIGIN=http://localhost:5173
# ORIGIN=

# Optional: length of room codes. Default 6.
# ROOM_ID_LEN=6

# Optional: when behind a proxy, set to x-forwarded-for for rate limits by real client IP.
# ADDRESS_HEADER=x-forwarded-for

# Test-only: raise the player/projector join rate limit for benchmarking deployments.
# Keep this unset in normal production use.
# LOAD_TEST_PLAYER_JOIN_MAX=250
